# Copy to .env and fill in real values. Never commit .env.

# Required: the Discord bot token (Developer Portal → Bot → Reset Token)
DISCORD_BOT_TOKEN=

# Required: the crawler API key (run `python -m src.scripts.create_api_key --name manhwa-bot` in crawler_backend)
CRAWLER_API_KEY=

# Optional: Patreon access token for Patreon-tier premium detection.
# Generate at https://www.patreon.com/portal/registration/register-clients
# (Creator tools → My Apps → Create OAuth Client → use the creator's access token).
# Leave blank to disable Patreon premium source.
PATREON_ACCESS_TOKEN=
